{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "@playwright/test"],
    "lib": ["ESNext", "DOM"],
    "rootDir": "./test",
    "ignoreDeprecations": "6.0"
  },
  "include": ["test/**/*.ts"]
}
